@model YourApp.Models.Book

@{
    ViewData["Title"] = "Delete Book";
}

<h2>Delete Book</h2>

<div class="alert alert-warning">
    Are you sure you want to delete this book?
</div>

<dl class="row">
    <dt class="col-sm-3">Title</dt>
    <dd class="col-sm-9">@Model.title</dd>

    <dt class="col-sm-3">Genre</dt>
    <dd class="col-sm-9">@Model.genre</dd>

    <dt class="col-sm-3">Price</dt>
    <dd class="col-sm-9">@Model.price.ToString("C")</dd>

    <dt class="col-sm-3">Year</dt>
    <dd class="col-sm-9">@Model.publicationYear</dd>

    <dt class="col-sm-3">Author</dt>
    <dd class="col-sm-9">@Model.Author?.firstName @Model.Author?.lastName</dd>
</dl>

<form asp-action="Delete">
    <input type="hidden" asp-for="bookId" />
    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
