@model IEnumerable<YourApp.Models.Author>

@{
    ViewData["Title"] = "Authors";
}

<h2>Authors</h2>
<p>
    <a asp-action="Create" class="btn btn-primary">Add New Author</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Bio</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var author in Model)
        {
            <tr>
                <td>@author.firstName</td>
                <td>@author.lastName</td>
                <td>@author.bio</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@author.authorId" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@author.authorId" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
